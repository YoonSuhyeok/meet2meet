---
// Standalone full-screen Scalar API reference page.
// Loads the OpenAPI spec from /openapi/MEETING_API_SPEC.yaml at runtime.
---

<!doctype html>
<html lang="ko">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>Meeting API · Meet2Meet</title>
		<link rel="icon" href="/favicon.svg" type="image/svg+xml" />
		<style>
			html,
			body {
				margin: 0;
				padding: 0;
				min-height: 100%;
				background: #ffffff;
			}
			#app {
				min-height: 100vh;
			}
		</style>
	</head>
	<body>
		<div id="app"></div>
		<script>
			import { createApiReference } from "@scalar/api-reference";
			import "@scalar/api-reference/style.css";

			createApiReference("#app", {
				url: "/openapi/MEETING_API_SPEC.yaml",
				theme: "default",
				layout: "modern",
				darkMode: false,
				metaData: {
					title: "Meeting API",
				},
			});
		</script>
	</body>
</html>
