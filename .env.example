# Base URL for meet2meet app (used for OAuth callback and cookie security)
BASE_URL=http://localhost:3000

# JWT signing secret used by auth and meeting proxy
JWT_SECRET=change-this-to-a-long-random-string

# Go core API base URL (optional in code, defaults to http://localhost:8080)
CORE_API_URL=http://localhost:8080

# OAuth client credentials
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
