# Base URL for meet2meet app (used for OAuth callback and cookie security)
BASE_URL=http://localhost:3000

# JWT signing secret used by auth and meeting proxy
JWT_SECRET=change-this-to-a-long-random-string

# Go core API base URL (optional in code, defaults to http://localhost:8080)
CORE_API_URL=http://localhost:8080

# Web Push VAPID public key for browser subscription creation
VITE_VAPID_PUBLIC_KEY=

# Optional: allow /api/auth/test-login outside localhost (use only for safe test envs)
TEST_LOGIN_ENABLED=false

# Optional: show test account buttons on /login in non-DEV mode
VITE_TEST_LOGIN_ENABLED=false

# OAuth client credentials
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
